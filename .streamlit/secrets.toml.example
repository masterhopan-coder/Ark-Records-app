# =============================================================================
# 방주의 기록 - Secrets 예시 파일 (수동 OAuth 2.0 방식)
# =============================================================================
# 사용법:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml  (macOS/Linux)
#   copy .streamlit\secrets.toml.example .streamlit\secrets.toml (Windows)
# 그 다음 실제 값으로 교체하세요.
# secrets.toml 은 절대 GitHub에 올리지 마세요 (.gitignore 에 등록되어 있음).
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI (선택)
# -----------------------------------------------------------------------------
[openai]
api_key = "sk-여기에_OpenAI_API_KEY"
text_model = "gpt-4o-mini"
transcription_model = "whisper-1"


# -----------------------------------------------------------------------------
# Google OAuth 2.0 수동 방식 (선택)
# -----------------------------------------------------------------------------
#
# ★ redirect_uri 설정이 가장 중요합니다 ★
#
# 이 앱은 st.login() 을 쓰지 않고 Google Token API 를 직접 호출합니다.
# 따라서 redirect_uri 는 '/oauth2callback' 같은 경로가 붙으면 안 되고
# 앱의 기본 URL (루트) 이어야 합니다.
#
#   로컬 개발:  http://localhost:8501
#   Streamlit Cloud: https://YOUR-APP-NAME.streamlit.app
#
# Google Cloud Console (https://console.cloud.google.com/apis/credentials) 에서
# OAuth 클라이언트의 "승인된 리디렉션 URI" 에 아래 두 개를 모두 등록하세요.
#
#   http://localhost:8501
#   https://YOUR-APP-NAME.streamlit.app
#
# ※ 끝에 슬래시(/) 없이 정확히 위 형태여야 합니다.
# ※ cookie_secret / server_metadata_url 은 더 이상 필요하지 않습니다.
#
[auth]
redirect_uri  = "http://localhost:8501"
client_id     = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"


# -----------------------------------------------------------------------------
# Telegram (선택)
# -----------------------------------------------------------------------------
# Bot 만들기:
#   1) @BotFather → /newbot → 토큰 발급
#   2) 봇과 대화방을 한 번 시작 후
#      https://api.telegram.org/bot<TOKEN>/getUpdates 로 chat_id 확인
[telegram]
token   = "YOUR_TELEGRAM_BOT_TOKEN"
chat_id = "YOUR_TELEGRAM_CHAT_ID"
